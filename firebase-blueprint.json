{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "governorate": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["vodafone", "cod"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "ready", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "vodafoneReceiptUrl": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "customerName", "phone", "address", "governorate", "totalAmount", "paymentMethod", "status", "createdAt", "items"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "password": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store customer orders"
    },
    "/settings/admin": {
      "schema": "Setting",
      "description": "Admin configuration like password"
    }
  }
}
