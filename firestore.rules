rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper for basic ID validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /orders/{orderId} {
      // Allow creation for everyone
      allow create: if isValidId(orderId);
      
      // Allow reading individual documents if ID is valid
      allow get: if isValidId(orderId);

      // Allow listing, updating, and deleting
      // We don't use isValidId on 'list' operations
      allow list, update, delete: if true;
    }

    match /settings/admin {
      allow read, write: if true;
    }
  }
}
